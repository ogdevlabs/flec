# Flec environment configuration
# Copy this file to .env and fill in values for your environment

# Camera device index (0 = default/first camera, 1 = second camera)
FLEC_CAMERA_INDEX=0

# Enable development mode (uses iPhone Bluetooth camera proxy)
FLEC_DEV_MODE=true

# Logging level: DEBUG | INFO | WARNING | ERROR
FLEC_LOG_LEVEL=INFO

# TTS voice character to use (default = built-in kid-friendly voice)
FLEC_TTS_VOICE=default

# Wake word string (must match the trained model file name in .models/)
FLEC_WAKE_WORD=hey_flec
